// 이 파일은 데이터베이스의 구조를 정의하는 설계도입니다.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL") // Vercel용 주소
  directUrl = env("POSTGRES_URL_NON_POOLING") // Vercel용 직통 주소
}

// 1. 사용자 (환자 + 병원 관리자 + 최고 관리자)
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  role          String    @default("PATIENT")
  name          String?
  phone         String?
  country       String?   @default("KR")

  hospitalId    String?
  hospital      Hospital? @relation(fields: [hospitalId], references: [id])
  status        String    @default("ACTIVE")

  leads         Lead[]
  reviews       Review[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([role])
  @@index([hospitalId])
}

// 2. 병원 정보
model Hospital {
  id        String   @id @default(uuid())
  slug      String   @unique

  name      Json
  intro     Json
  about     Json
  address   Json
  cautions  Json

  city      String
  district  String
  lat       Float?
  lng       Float?

  category  String
  tags      String

  // image=대표 썸네일, images=갤러리(추가 사진)
  image     String
  images    String[]

  rating    Float    @default(0)
  reviews   Int      @default(0)

  operatingHours Json
  // { whatsapp, line, wechat, kakao, messenger, phone, email }
  messengers     Json

  isPublished Boolean @default(false)
  tier      String  @default("RECOMMENDED")
  benefits  Json    @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors     Doctor[]
  menus       Menu[]
  userReviews Review[]
  treatments  Treatment[]
  leads       Lead[]
  bookings    Booking[]
  users       User[]

  @@index([city, category])
  @@index([isPublished])
  @@index([tier])
}

// 👨‍⚕️ 의사 선생님 정보
model Doctor {
  id         String   @id @default(uuid())
  name       Json
  specialty  Json
  image      String?
  order      Int      @default(0)
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id])

  @@index([hospitalId])
}

// 📋 시술 메뉴/가격표
model Menu {
  id         String   @id @default(uuid())
  name       Json
  category   String   @default("ETC")
  price      Int?
  priceText  Json
  currency   String   @default("KRW")
  order      Int      @default(0)
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id])

  @@index([hospitalId])
}

// ⭐ 후기(리뷰) 시스템
model Review {
  id           String   @id @default(uuid())
  userName     String   // 작성자 이름 (익명 레거시 보존; 신규는 계정명)
  rating       Int      // 1~5점
  content      String   // 후기 내용
  hospitalId   String
  hospital     Hospital @relation(fields: [hospitalId], references: [id])
  authorUserId String?  // 신규: 로그인 작성자 (nullable, 기존 익명 후기 보존)
  author       User?    @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([authorUserId])
}

// 3. 시술 상품 (예: 울쎄라 300샷, 코수술 등)
model Treatment {
  id            String    @id @default(uuid())
  name          String    // 시술명
  category      String    // 카테고리 (피부, 성형, 치과...)
  priceMin      Int       // 최소 가격
  priceMax      Int       // 최대 가격
  description   String?   // 시술 상세 설명
  
  hospitalId    String    // 어느 병원 상품인지 연결
  hospital      Hospital  @relation(fields: [hospitalId], references: [id])
  
  createdAt     DateTime  @default(now())
}

// 4. 상담/예약 (Lead) - 비즈니스의 핵심!
model Lead {
  id            String    @id @default(uuid())
  referralCode  String    @unique // 나중에 QR코드로 만들 고유 번호
  
  status        String    @default("PENDING") 
  // 상태값: PENDING(접수) -> VISITED(내원) -> DONE(시술완료/결제) -> CANCELLED
  
  concern       String?   // 환자의 고민 (예: "코가 낮아요")
  quotedPrice   Int?      // 확정된 견적 금액
  
  photo         String?   // 👈 [추가] 사진 데이터를 저장할 칸 (Base64 문자열)

  userId        String    // 신청한 환자 ID
  user          User      @relation(fields: [userId], references: [id])
  
  hospitalId    String?   // 지정된 병원 ID (없으면 미지정)
  hospital      Hospital? @relation(fields: [hospitalId], references: [id])

  settlement    Settlement? // 정산 내역 (1:1 연결)
  
  visitedAt     DateTime? // 병원 방문 시간
  createdAt     DateTime  @default(now())
}

// 5. 정산 (돈 관리)
model Settlement {
  id            String    @id @default(uuid())
  amount        Int       // 총 결제 금액
  fee           Int       // 우리가 가져갈 수수료
  isPaid        Boolean   @default(false) // 병원이 우리한테 입금 했는지 여부
  
  leadId        String    @unique // 어떤 상담 건에 대한 정산인지
  lead          Lead      @relation(fields: [leadId], references: [id])
  
  createdAt     DateTime  @default(now())
}
// 👇 맨 아래에 추가하세요!
model Consultation {
  id        String   @id @default(uuid())
  customerName String?
  phone     String
  content   String
  imageUrl  String?
  password  String?
  createdAt DateTime @default(now())
}

model Booking {
  id            String   @id @default(uuid())
  code          String   @unique
  status        String   @default("NEW")
  locale        String   @default("ko")

  groupId       String?

  hospitalId    String
  hospital      Hospital @relation(fields: [hospitalId], references: [id])

  name          String
  phone         String
  nationality   String
  email         String?
  age           Int?
  gender        String?

  messengerChannel String?
  messengerHandle  String?

  treatmentInterest String?
  memo          String?
  photo         String?

  preferredDate1 DateTime
  preferredDate2 DateTime?
  timeOfDay      String

  consent        Boolean  @default(false)

  adminNote      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([hospitalId])
  @@index([groupId])
}