# RICH DOC — 환경변수 예시 (.env.example)
# 실제 값은 .env / .env.local 또는 Vercel 프로젝트 환경변수에 등록한다. 이 파일은 키 목록·용도만 문서화한다.
# 모든 알림/업로드 키는 "없어도 앱·예약은 동작"하며, 해당 기능만 조용히 스킵된다(graceful skip).

# ── 데이터베이스 (Neon Postgres — Vercel 연동 시 자동 주입) ───────────────
# Vercel ↔ Neon 통합으로 자동 제공됨. 로컬은 `vercel env pull .env.local`로 가져온다.
POSTGRES_PRISMA_URL=          # Prisma용(pgbouncer 풀링)
POSTGRES_URL_NON_POOLING=     # 마이그레이션용 직통 연결
DATABASE_URL=                 # 기타 도구용
# (그 외 PGHOST/PGUSER/... 등 Vercel-Neon 템플릿 변수들도 함께 주입됨)

# ── 관리자 인증 (Phase 1) ─────────────────────────────────────────────
ADMIN_PASSWORD=               # 관리자 로그인 비밀번호 (강한 값으로)
ADMIN_SESSION_SECRET=         # 세션 쿠키 HMAC 서명 키. 생성: openssl rand -hex 32
                              # ⚠️ 프로덕션에서 미설정 시 의도적으로 에러를 던진다(보안).

# ── 사진 업로드: Vercel Blob (Phase 3) ───────────────────────────────
# Vercel 대시보드 → Storage → Blob 스토어 생성 시 자동 발급/주입.
# 로컬은 토큰을 복사해 넣는다. 없으면 예약 사진 업로드만 스킵.
BLOB_READ_WRITE_TOKEN=

# ── 이메일 알림: Resend (Phase 3) ────────────────────────────────────
# resend.com 가입 → API Keys에서 발급. 도메인 인증 후 발신주소 설정.
RESEND_API_KEY=               # re_... 형식
RESEND_FROM=                  # 예: "RICH DOC <noreply@yourdomain.com>" (인증된 도메인)

# ── 텔레그램 관리자 알림 (Phase 3) ───────────────────────────────────
# @BotFather로 봇 생성 → 토큰. 관리자 채팅에 봇 추가 후 chat id 확인
# (예: 봇과 대화 시작 후 https://api.telegram.org/bot<TOKEN>/getUpdates 에서 chat.id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── 관리자 이메일 수신 (Phase 3) ─────────────────────────────────────
ADMIN_NOTIFY_EMAIL=           # 신규 예약 알림을 받을 운영자 이메일
